run = "uvicorn main:app --host 0.0.0.0 --port 8000"

[nix]
channel = "stable-22_11"

[env]
ENVIRONMENT = "production"
MOCK_DATA_PATH = "/home/runner/${REPL_SLUG}/mock_data"
AI_MODELS_PATH = "/home/runner/${REPL_SLUG}/ai_models"
PORT = "8000"

[packager]
language = "python3"

[packager.features]
enabledForHosting = false
packageSearch = true
guessImports = true

[[ports]]
localPort = 8000
externalPort = 80
