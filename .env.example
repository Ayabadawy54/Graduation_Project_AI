# Environment variables for Docker Compose

# Database
DATABASE_URL=postgresql://talentree_user:talentree_password_2026@postgres:5432/talentree
POSTGRES_DB=talentree
POSTGRES_USER=talentree_user
POSTGRES_PASSWORD=talentree_password_2026

# API
API_TITLE=TalentTree Admin Dashboard API
API_VERSION=4.0.0
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost

# Paths
MOCK_DATA_PATH=/app/mock_data
AI_MODELS_PATH=/app/ai_models

# Redis (optional)
REDIS_URL=redis://redis:6379

# Jupyter
JUPYTER_ENABLE_LAB=yes
